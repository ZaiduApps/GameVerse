APP_ENV=development
PORT=3002

# Backend API endpoints
API_BASE_URL_DEV=http://127.0.0.1:9527
API_BASE_URL_PROD=https://api.hk.apks.cc

# Optional explicit override for API base URL
# API_BASE_URL=

# Home + Game Detail announcement filter context
NEXT_PUBLIC_CLIENT_PLATFORM=android
NEXT_PUBLIC_CLIENT_REGION=
NEXT_PUBLIC_CLIENT_VERSION=1.0.0

# Optional: site style preset (magazine | classic)
NEXT_PUBLIC_SITE_STYLE=magazine

# Optional: site config key
SITE_CONFIG_KEY=main

# Optional: home dynamic posts count (1~20)
HOME_DYNAMIC_COUNT=8
